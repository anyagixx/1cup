  <DataFlows>
    <DataFlow id="DF-001" from="M-FE-AUTH" to="M-BE-AUTH">
      <Description>Login credentials → JWT token</Description>
      <Format>JSON over HTTP</Format>
    </DataFlow>
    <DataFlow id="DF-002" from="M-BE-API-*" to="M-BE-1C-RAC">
      <Description>API requests → rac commands</Description>
      <Format>Function calls</Format>
    </DataFlow>
    <DataFlow id="DF-003" from="M-BE-1C-RAC" to="1C Cluster">
      <Description>rac CLI execution</Description>
      <Format>Subprocess</Format>
    </DataFlow>
    <DataFlow id="DF-004" from="M-BE-WS" to="M-FE-*">
      <Description>Real-time events</Description>
      <Format>WebSocket JSON</Format>
    </DataFlow>
    <DataFlow id="DF-005" from="M-BE-*" to="M-BE-CACHE">
      <Description>Cached responses</Description>
      <Format>Redis protocol</Format>
    </DataFlow>
  </DataFlows>
</DevelopmentPlan>
